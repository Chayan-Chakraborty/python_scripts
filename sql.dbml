Ref: app_user_v2.id > estimator.user_id
Table estimator {
  id int [not null]
  user_id int [not null]
  project_id int [not null]
  project_type varchar(10)
  is_default tinyint(1) [default: "0"]
  url varchar(255)
  discount float(5,2)
  gst float(5,2)
  amount decimal(11,2)
  total_amount decimal(11,2)
  expiry_date timestamp [not null]
  created_by int [not null]
  updated_by int [not null]
  created_at timestamp [not null, default: "CURRENT_TIMESTAMP"]
  updated_at timestamp [not null, default: "CURRENT_TIMESTAMP"]
  type varchar(50)
  name varchar(255)
  status varchar(20)
  is_active tinyint(1)
  description varchar(255)
  additional_info text
  selection_attribute text
  parent_estimator_id int
  org_id bigint [not null]
}

Table item {
  id int [not null]
  room_id int [not null]
  name varchar(255)
  identifier varchar(50)
  amount decimal(11,2)
  attributes text
  created_by int
  updated_by int
  created_at timestamp [not null, default: "CURRENT_TIMESTAMP"]
  updated_at timestamp [not null, default: "CURRENT_TIMESTAMP"]
  type varchar(50)
  image json [not null]
  type_identifier varchar(50)
  room_identifier varchar(50)
  description varchar(255)
}

Ref: item.room_id > room.id
